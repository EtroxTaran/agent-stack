# agent-stack — Example environment variables
#
# Copy to ~/.openclaw/.env (shared across this host) and fill in real values.
# This file lists the KEYS only, never commit real secrets.
#
# Source of truth: ~/.openclaw/.env (not this file).
# MCP servers and ops-n8n read variables from there via env_file.

# ---------------------------------------------------------------------------
# Telegram — legacy, will be removed in Phase 5 (switch to Discord)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------------------------------------------------------------------------
# Discord — primary messaging bridge (Phase 3+)
# One bot, many channels. Channel-IDs per project.
# ---------------------------------------------------------------------------
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=

# Per-project channel IDs (Discord Developer-Mode → Right-Click → Copy ID)
DISCORD_CHANNEL_ID_AI_PORTAL=
DISCORD_CHANNEL_ID_NATHAN_COCKPIT=
DISCORD_CHANNEL_ID_OPENCLAW_OFFICE=
DISCORD_CHANNEL_ID_RESEARCH_WORKFLOW_N8N=
DISCORD_CHANNEL_ID_ALERTS_GLOBAL=

# ---------------------------------------------------------------------------
# GitHub
# ---------------------------------------------------------------------------
# PAT used by n8n / workflow-runners to call the GitHub API.
GITHUB_TOKEN=

# Same PAT under the env-var-name the github MCP-server expects.
GITHUB_PERSONAL_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# LLM-API-Keys — only for n8n / non-CLI consumers.
# Claude Code, Codex, Cursor, Gemini CLIs use OAuth, NOT these keys.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Research stack (MCP servers + research.py)
# ---------------------------------------------------------------------------
BRAVE_API_KEY=
PERPLEXITY_API_KEY=
TAVILY_API_KEY=
